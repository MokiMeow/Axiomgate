# AxiomGate configuration example
#
# All values are optional. Set the ones you need as environment variables.
# Copy this file, fill in your own values, and never commit real credentials.

# ---------------------------------------------------------------------------
# Dashboard and workspace
# ---------------------------------------------------------------------------

# Governed workspace the dashboard reads. Defaults to the current directory.
# AXIOMGATE_WORKSPACE=C:\path\to\your\project

# Dashboard port. Defaults to 4319.
# AXIOMGATE_PORT=4319

# Serve the bundled curated sample missions instead of live workspace state.
# Without this, a fresh clone shows an empty state until you run a mission.
# AXIOMGATE_DEMO=true

# Override the Codex home directory used for hook and plugin discovery.
# CODEX_HOME=C:\Users\you\.codex

# ---------------------------------------------------------------------------
# Telegram approvals (optional)
# ---------------------------------------------------------------------------
# The bot token is a credential. Keep it out of the repository, out of logs,
# and out of shared transcripts. Rotate it immediately if it is exposed.

# Required for Telegram. BotFather token. A leading "bot" prefix is stripped.
# TELEGRAM_BOT_TOKEN=123456789:AAaaBBbbCCccDDddEEffGGhhIIjjKKllMMnn

# Required for Telegram. Comma-separated numeric allowlist of chats that may
# receive messages. Group ids are negative, private chat ids are positive.
# TELEGRAM_CHAT_ID=123456789

# Comma-separated allowlist of Telegram user ids permitted to approve or deny.
# Positive integers only. Omit this to fall back to private-chat-only
# approval, which is the safer default.
# TELEGRAM_USER_ID=123456789

# Which events are sent. One of: all, approvals, off. Defaults to all.
# TELEGRAM_NOTIFY=all

# Weekly Codex usage percentage that triggers a capacity warning.
# Greater than 0 and at most 100. Defaults to 80.
# TELEGRAM_NOTIFY_USAGE_PCT=80
